<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SS14.Launcher.Localization"
        mc:Ignorable="d"
        d:DesignWidth="300"
        d:DesignHeight="100"
        MinWidth="440"
        MinHeight="220"
        Width="440"
        Height="220"
        Background="#0F141C"
        x:Class="SS14.Launcher.Views.Helix.DirectConnectDialogHelix"
        Icon="{DynamicResource WindowIcon}"
        Title="{loc:Loc direct-connect-title}"
        WindowStartupLocation="CenterOwner">

  <Window.Styles>
    <Style Selector="Border.HelixDialogCard">
      <Setter Property="Background" Value="#151B24" />
      <Setter Property="BorderBrush" Value="#1F2935" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="BoxShadow" Value="0 20 40 0 #50000000" />
    </Style>

    <Style Selector="TextBlock.HelixDialogTitle">
      <Setter Property="Foreground" Value="#E5E9F0" />
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.HelixDialogError">
      <Setter Property="Foreground" Value="#F27A7A" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="TextBox.HelixDialogInput">
      <Setter Property="Background" Value="#0F141C" />
      <Setter Property="Foreground" Value="#E5E9F0" />
      <Setter Property="BorderBrush" Value="#1F2935" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="MinHeight" Value="46" />
    </Style>

    <Style Selector="TextBox.HelixDialogInput:focus">
      <Setter Property="Background" Value="#111926" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>

    <Style Selector="Button.HelixDialogButton">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Background" Value="#111824" />
      <Setter Property="BorderBrush" Value="#1F2935" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E5E9F0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="999">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              TextBlock.Foreground="{TemplateBinding Foreground}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="Button.HelixDialogButton:pointerover">
      <Setter Property="Background" Value="#162132" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>

    <Style Selector="Button.HelixDialogButton:pressed">
      <Setter Property="Background" Value="#1A2639" />
      <Setter Property="BorderBrush" Value="#5C91F5" />
    </Style>

    <Style Selector="Button.HelixDialogButton:disabled">
      <Setter Property="Background" Value="#121821" />
      <Setter Property="BorderBrush" Value="#243041" />
      <Setter Property="Foreground" Value="#6F7A8B" />
    </Style>

    <Style Selector="Button.HelixDialogPrimary">
      <Setter Property="Background" Value="#162235" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>
  </Window.Styles>

  <Border Margin="16"
          Padding="24"
          Classes="HelixDialogCard">
    <Grid RowDefinitions="Auto,Auto,Auto">
      <TextBlock Classes="HelixDialogTitle"
                 Text="{loc:Loc direct-connect-text}" />

      <TextBox Grid.Row="1"
               Margin="0,16,0,0"
               Name="AddressBox"
               Classes="HelixDialogInput"
               Watermark="ss14://example.com:1212" />

      <Grid Grid.Row="2"
            Margin="0,16,0,0"
            ColumnDefinitions="*,Auto">
        <TextBlock Name="InvalidLabel"
                   Classes="HelixDialogError"
                   VerticalAlignment="Center"
                   Text="{loc:Loc direct-connect-address-invalid}" />

        <Button Grid.Column="1"
                Margin="16,0,0,0"
                Name="SubmitButton"
                Classes="HelixDialogButton HelixDialogPrimary"
                Content="{loc:Loc direct-connect-connect}" />
      </Grid>
    </Grid>
  </Border>
</Window>
