    <Style Selector="helixViews|AccountDropDownHelix v|DropDown, v|LanguageSelector v|DropDown">
      <Setter Property="Background" Value="#111824" />
      <Setter Property="BorderBrush" Value="#1F2935" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="999">
            <Grid Margin="16,10" ColumnDefinitions="*,Auto">
              <ContentPresenter Content="{TemplateBinding HeaderContent}"
                                ContentTemplate="{TemplateBinding HeaderContentTemplate}" />
              <Path Grid.Column="1"
                    Fill="#E5E9F0"
                    Width="8"
                    Height="4"
                    Stretch="Uniform"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Data="F1 M 301.14,-189.041L 311.57,-189.041L 306.355,-182.942L 301.14,-189.041 Z" />
              <Popup Name="PART_Popup"
                     PlacementTarget="{TemplateBinding}"
                     Placement="{TemplateBinding Placement}"
                     IsOpen="{TemplateBinding IsDropDownOpen,Mode=TwoWay}"
                     IsLightDismissEnabled="True"
                     MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}">
                <Border Background="#0F141C"
                        BorderBrush="#1F2935"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="8">
                  <ContentPresenter Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
              </Popup>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

