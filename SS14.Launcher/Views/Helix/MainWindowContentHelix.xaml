  <Panel Background="#0F141C">
    <Border IsVisible="{Binding LoggedIn}"
            Margin="12,6,12,0"
            Classes="HelixShellCard">
      <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0"
              Margin="28,24,28,18"
              ColumnDefinitions="*,Auto">
          <StackPanel Spacing="6">
            <TextBlock Text="{loc:Loc helix-shell-brand}"
                       Classes="HelixTitle" />
            <TextBlock Text="{Binding HomeTab.Name}"
                       Classes="HelixSubtitle" />
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="10"
                      VerticalAlignment="Top">
            <Button Classes="HelixPillButton"
                    Command="{Binding OnDiscordButtonPressed}">
              <v:IconLabel Icon="{DynamicResource InfoIcon-discord}"
                           Content="{loc:Loc main-window-header-link-discord}" />
            </Button>

            <Button Classes="HelixPillButton"
                    Command="{Binding OnWebsiteButtonPressed}">
              <v:IconLabel Icon="{DynamicResource InfoIcon-web}"
                           Content="{loc:Loc main-window-header-link-website}" />
            </Button>

            <Border Classes="HelixBadge"
                    VerticalAlignment="Center">
              <TextBlock Foreground="#5C91F5"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Text="{Binding Version}" />
            </Border>

            <helixViews:AccountDropDownHelix IsVisible="{Binding AccountDropDownVisible}" />
          </StackPanel>
        </Grid>

        <Border Grid.Row="0"
                Margin="28,0,28,0"
                VerticalAlignment="Bottom"
                Classes="HelixDivider" />

        <ContentControl Grid.Row="1"
                        x:Name="SelectedTabContent"
                        Margin="28,22,28,22" />

        <Border Grid.Row="2"
                BorderBrush="#1F2935"
                BorderThickness="0,1,0,0"
                Background="#151B24">
          <DockPanel Margin="20,12,20,12">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button x:Name="NavHomeButton"
                      Classes="HelixTabButton"
                      Click="NavHomeClicked"
                      Content="{loc:Loc helix-shell-nav-home}" />
              <Button x:Name="NavServersButton"
                      Classes="HelixTabButton"
                      Click="NavServersClicked"
                      Content="{loc:Loc helix-shell-nav-servers}" />
              <Button x:Name="NavNewsButton"
                      Classes="HelixTabButton"
                      Click="NavNewsClicked"
                      Content="{loc:Loc helix-shell-nav-news}" />
              <Button x:Name="NavPatchesButton"
                      Classes="HelixTabButton"
                      Click="NavPatchesClicked"
                      Content="{loc:Loc helix-shell-nav-patches}" />
              <Button x:Name="NavOptionsButton"
                      Classes="HelixTabButton"
                      Click="NavOptionsClicked"
                      Content="{loc:Loc helix-shell-nav-settings}" />
            </StackPanel>

          </DockPanel>
        </Border>
      </Grid>
    </Border>

    <helixViews:MainWindowLoginHelix IsVisible="{Binding !$parent.DataContext.LoggedIn}"
                                   DataContext="{Binding LoginViewModel}" />

    <ContentControl Classes="OverlayBox"
                    IsVisible="{Binding LoginViewModel.Screen.OverlayControl, Converter={x:Static ObjectConverters.IsNotNull}}">
      <ContentControl Content="{Binding LoginViewModel.Screen.OverlayControl}" />
    </ContentControl>

    <ContentControl Classes="OverlayBox"
                    IsVisible="{Binding LoginViewModel.Screen.Busy}">
      <StackPanel Orientation="Vertical"
                  VerticalAlignment="Center">
        <Viewbox Classes="DungSpinnerBox">
          <v:DungSpinner IsVisible="{Binding LoginViewModel.Screen.Busy}" />
        </Viewbox>
        <TextBlock Text="{Binding LoginViewModel.Screen.BusyText}"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </ContentControl>

    <ContentControl Classes="OverlayBox"
                    IsVisible="{Binding OverlayViewModel, Converter={x:Static ObjectConverters.IsNotNull}}">
      <ContentControl Content="{Binding OverlayViewModel}" />
    </ContentControl>

    <ContentControl Classes="OverlayBox"
                    IsVisible="{Binding BusyTask, Converter={x:Static ObjectConverters.IsNotNull}}">
      <StackPanel Orientation="Vertical">
        <Viewbox Classes="DungSpinnerBox">
          <v:DungSpinner DockPanel.Dock="Top"
                         IsVisible="{Binding BusyTask, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </Viewbox>
        <TextBlock Text="{Binding BusyTask}"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </ContentControl>

    <ContentControl Classes="OverlayBox"
                    IsVisible="{Binding OutOfDate}">
      <StackPanel Orientation="Vertical">
        <TextBlock HorizontalAlignment="Center"
                   Classes="NanoHeadingMedium"
                   Text="{loc:Loc main-window-out-of-date}" />
        <TextBlock Margin="0,10"
                   TextAlignment="Center"
                   Text="{loc:Loc main-window-out-of-date-desc}" />
        <DockPanel LastChildFill="False">
          <Button DockPanel.Dock="Right"
                  Content="{loc:Loc main-window-out-of-date-exit}"
                  Command="{Binding ExitPressed}" />
          <Button DockPanel.Dock="Left"
                  Content="{loc:Loc main-window-out-of-date-download-manual}"
                  Command="{Binding DownloadPressed}" />
        </DockPanel>
      </StackPanel>
    </ContentControl>

    <ContentControl Classes="OverlayBox"
                    IsVisible="{Binding !HasDismissedEarlyAccessWarning.Value}">
      <StackPanel Orientation="Vertical">
        <TextBlock HorizontalAlignment="Center"
                   Classes="NanoHeadingMedium"
                   Text="{loc:Loc main-window-early-access-title}" />
        <TextBlock Margin="0,10"
                   MaxWidth="450"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Text="{loc:Loc main-window-early-access-desc}" />
        <Button Content="{loc:Loc main-window-early-access-accept}"
                Command="{Binding DismissEarlyAccessPressed}"
                HorizontalAlignment="Center" />
      </StackPanel>
    </ContentControl>

    <ContentControl Classes="OverlayBox"
                    IsVisible="{Binding ShouldShowIntelDegradationWarning}">
      <StackPanel Orientation="Vertical">
        <TextBlock HorizontalAlignment="Center"
                   Classes="NanoHeadingMedium"
                   Text="{loc:Loc main-window-intel-degrade-title}" />
        <TextBlock Margin="0,10"
                   MaxWidth="450"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Text="{loc:Loc main-window-intel-degrade-desc}" />
        <Button Content="{loc:Loc main-window-intel-degrade-accept}"
                Command="{Binding DismissIntelDegradationPressed}"
                HorizontalAlignment="Center" />
      </StackPanel>
    </ContentControl>

    <ContentControl Classes="OverlayBox"
                    IsVisible="{Binding ShouldShowRosettaWarning}">
      <StackPanel Orientation="Vertical">
        <TextBlock HorizontalAlignment="Center"
                   Classes="NanoHeadingMedium"
                   Text="{loc:Loc main-window-rosetta-title}" />
        <TextBlock Margin="0,10"
                   MaxWidth="450"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Text="{loc:Loc main-window-rosetta-desc}" />
        <Button Content="{loc:Loc main-window-rosetta-accept}"
                Command="{Binding DismissAppleSiliconRosettaPressed}"
                HorizontalAlignment="Center" />
      </StackPanel>
    </ContentControl>

    <v:ConnectingOverlay DataContext="{Binding ConnectingVM}"
                         IsVisible="{Binding $parent.DataContext.ConnectingVM, Converter={x:Static ObjectConverters.IsNotNull}}" />

    <ContentControl Classes="OverlayBox"
                    Name="DragDropOverlay"
                    IsVisible="False">
      <TextBlock Text="{loc:Loc main-window-drag-drop-prompt}" />
    </ContentControl>
  </Panel>
</UserControl>
