<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SS14.Launcher.ViewModels;assembly=SS14.Launcher"
             xmlns:views="clr-namespace:SS14.Launcher.Views"
             xmlns:loc="clr-namespace:SS14.Launcher.Localization"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="SS14.Launcher.Views.Helix.MainWindowLoginHelix">
  <Design.DataContext>
    <vm:MainWindowLoginViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Border.HelixLoginCard">
      <Setter Property="Background" Value="#151B24" />
      <Setter Property="BorderBrush" Value="#1F2935" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="BoxShadow" Value="0 20 40 0 #50000000" />
    </Style>

    <Style Selector="Border.HelixLoginDivider">
      <Setter Property="Background" Value="#1F2935" />
      <Setter Property="Height" Value="1" />
    </Style>

    <Style Selector="TextBlock.HelixLoginBrand">
      <Setter Property="Foreground" Value="#E5E9F0" />
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.HelixLoginSectionTitle">
      <Setter Property="Foreground" Value="#E5E9F0" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.NanoHeadingMedium">
      <Setter Property="Foreground" Value="#E5E9F0" />
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.SubText">
      <Setter Property="Foreground" Value="#8A95A8" />
    </Style>

    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#8A95A8" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="#0F141C" />
      <Setter Property="Foreground" Value="#E5E9F0" />
      <Setter Property="BorderBrush" Value="#1F2935" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="MinHeight" Value="46" />
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="Background" Value="#111926" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>

    <Style Selector="Button">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Background" Value="#111824" />
      <Setter Property="BorderBrush" Value="#1F2935" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E5E9F0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="999">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              TextBlock.Foreground="{TemplateBinding Foreground}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#162132" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="#1A2639" />
      <Setter Property="BorderBrush" Value="#5C91F5" />
    </Style>

    <Style Selector="Button:disabled">
      <Setter Property="Background" Value="#121821" />
      <Setter Property="BorderBrush" Value="#243041" />
      <Setter Property="Foreground" Value="#6F7A8B" />
    </Style>

    <Style Selector="Button.BigButton">
      <Setter Property="Background" Value="#162235" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>

    <Style Selector="Button.HelixStoredAccountButton">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="14,12" />
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#E5E9F0" />
    </Style>

    <Style Selector="views|LanguageSelector views|DropDown">
      <Setter Property="Background" Value="#111824" />
      <Setter Property="BorderBrush" Value="#1F2935" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="999">
            <Grid Margin="16,10" ColumnDefinitions="*,Auto">
              <ContentPresenter Content="{TemplateBinding HeaderContent}"
                                ContentTemplate="{TemplateBinding HeaderContentTemplate}" />
              <Path Grid.Column="1"
                    Fill="#E5E9F0"
                    Width="8"
                    Height="4"
                    Stretch="Uniform"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Data="F1 M 301.14,-189.041L 311.57,-189.041L 306.355,-182.942L 301.14,-189.041 Z" />
              <Popup Name="PART_Popup"
                     PlacementTarget="{TemplateBinding}"
                     Placement="{TemplateBinding Placement}"
                     IsOpen="{TemplateBinding IsDropDownOpen,Mode=TwoWay}"
                     IsLightDismissEnabled="True"
                     MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}">
                <Border Background="#0F141C"
                        BorderBrush="#1F2935"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10">
                  <ContentPresenter Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
              </Popup>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="views|LanguageSelector views|DropDown:pointerover">
      <Setter Property="Background" Value="#162132" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>

    <Style Selector="ScrollBar:vertical">
      <Setter Property="Width" Value="12" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="Background" Value="#111824" />
    </Style>

    <Style Selector="ScrollBar:horizontal">
      <Setter Property="Height" Value="12" />
      <Setter Property="Margin" Value="0,8,0,0" />
      <Setter Property="Background" Value="#111824" />
    </Style>

    <Style Selector="ScrollBar /template/ RepeatButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ScrollBar /template/ RepeatButton#lineupbutton, ScrollBar /template/ RepeatButton#linedownbutton, ScrollBar /template/ RepeatButton#lineleftbutton, ScrollBar /template/ RepeatButton#linerightbutton, ScrollBar /template/ RepeatButton#PART_LineUpButton, ScrollBar /template/ RepeatButton#PART_LineDownButton, ScrollBar /template/ RepeatButton#PART_LineLeftButton, ScrollBar /template/ RepeatButton#PART_LineRightButton">
      <Setter Property="Background" Value="#162235" />
      <Setter Property="BorderBrush" Value="#253246" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
    </Style>

    <Style Selector="ScrollBar:vertical /template/ RepeatButton#lineupbutton, ScrollBar:vertical /template/ RepeatButton#linedownbutton, ScrollBar:vertical /template/ RepeatButton#PART_LineUpButton, ScrollBar:vertical /template/ RepeatButton#PART_LineDownButton">
      <Setter Property="Height" Value="12" />
      <Setter Property="MinHeight" Value="12" />
    </Style>

    <Style Selector="ScrollBar:horizontal /template/ RepeatButton#lineleftbutton, ScrollBar:horizontal /template/ RepeatButton#linerightbutton, ScrollBar:horizontal /template/ RepeatButton#PART_LineLeftButton, ScrollBar:horizontal /template/ RepeatButton#PART_LineRightButton">
      <Setter Property="Width" Value="12" />
      <Setter Property="MinWidth" Value="12" />
    </Style>

    <Style Selector="ScrollBar /template/ RepeatButton#lineupbutton:pointerover, ScrollBar /template/ RepeatButton#linedownbutton:pointerover, ScrollBar /template/ RepeatButton#lineleftbutton:pointerover, ScrollBar /template/ RepeatButton#linerightbutton:pointerover, ScrollBar /template/ RepeatButton#PART_LineUpButton:pointerover, ScrollBar /template/ RepeatButton#PART_LineDownButton:pointerover, ScrollBar /template/ RepeatButton#PART_LineLeftButton:pointerover, ScrollBar /template/ RepeatButton#PART_LineRightButton:pointerover">
      <Setter Property="Background" Value="#1B2A42" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>

    <Style Selector="ScrollBar /template/ Thumb#thumb">
      <Setter Property="Background" Value="#243041" />
      <Setter Property="BorderBrush" Value="#30425A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Margin" Value="2" />
    </Style>

    <Style Selector="ScrollBar:vertical /template/ Thumb#thumb">
      <Setter Property="MinHeight" Value="24" />
    </Style>

    <Style Selector="ScrollBar:horizontal /template/ Thumb#thumb">
      <Setter Property="MinWidth" Value="24" />
    </Style>

    <Style Selector="ScrollBar /template/ Thumb#thumb:pointerover">
      <Setter Property="Background" Value="#2D3D54" />
      <Setter Property="BorderBrush" Value="#3D7DF0" />
    </Style>
  </UserControl.Styles>

  <Grid Background="#0F141C"
        RowDefinitions="*,Auto">
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Top"
            MaxWidth="620"
            Margin="24,24,24,18"
            Classes="HelixLoginCard">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32"
              RowDefinitions="Auto,Auto,Auto,Auto">
          <StackPanel Spacing="6">
            <TextBlock Text="Helix Launcher"
                       Classes="HelixLoginBrand" />
            <TextBlock Text="{loc:Loc main-window-title}"
                       Foreground="#8A95A8"
                       FontSize="13" />
          </StackPanel>

          <Border Grid.Row="1"
                  Margin="0,22,0,0"
                  Classes="HelixLoginDivider" />

          <ContentControl Grid.Row="2"
                          Margin="0,22,0,0"
                          Content="{Binding Screen}" />

          <StackPanel x:Name="StoredAccountsSection"
                      Grid.Row="3"
                      Margin="0,22,0,0"
                      Spacing="12"
                      IsVisible="False">
            <Border Classes="HelixLoginDivider" />
            <TextBlock Classes="HelixLoginSectionTitle"
                       Text="Сохранённые аккаунты" />
            <ItemsControl x:Name="StoredAccountsList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="HelixStoredAccountButton"
                          Click="StoredAccountClicked"
                          Tag="{Binding Account}">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Account.Username}"
                                 Foreground="#E5E9F0"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1"
                                 Margin="16,0,0,0"
                                 Text="{Binding StatusText}"
                                 Foreground="#8A95A8"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="1"
            Background="#151B24"
            BorderBrush="#1F2935"
            BorderThickness="0,1,0,0">
      <DockPanel Margin="20,12,20,12"
                 LastChildFill="False">
        <views:LanguageSelector DockPanel.Dock="Left"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0"
                                DataContext="{Binding LanguageSelector}" />

        <Button DockPanel.Dock="Left"
                Content="{loc:Loc tab-options-open-log-directory}"
                Command="{Binding OpenLogDirectory}" />
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
