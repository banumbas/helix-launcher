<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mainWindowTabs="clr-namespace:SS14.Launcher.ViewModels.MainWindowTabs"
             xmlns:loc="clr-namespace:SS14.Launcher.Localization"
             xmlns:views="clr-namespace:SS14.Launcher.Views"
             mc:Ignorable="d"
             d:DesignWidth="1240"
             d:DesignHeight="720"
             x:Class="SS14.Launcher.Views.Worm.OptionsTabWormView">
  <Design.DataContext>
    <mainWindowTabs:OptionsTabViewModel />
  </Design.DataContext>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="18">
      <Border Classes="WormSectionCard"
              Padding="18">
        <StackPanel Spacing="16">
          <TextBlock Text="{loc:Loc tab-options-title}"
                     Classes="WormSectionTitle" />

          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <Button x:Name="GeneralTabButton"
                    Classes="WormSegmentButton"
                    Click="ShowGeneralClicked"
                    Content="{loc:Loc tab-options-general-tab}" />
            <Button x:Name="WormLauncherTabButton"
                    Classes="WormSegmentButton"
                    Click="ShowWormClicked"
                    Content="{loc:Loc tab-options-worm-tab}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel x:Name="GeneralPanel"
                  Spacing="18">
        <Border Classes="WormSectionCard"
                Padding="18">
          <StackPanel Spacing="14">
            <TextBlock Text="{loc:Loc tab-options-general-tab}"
                       Classes="WormSectionTitle" />

            <Border Classes="WormInsetCard"
                    Padding="14">
              <StackPanel Spacing="12">
                <TextBlock Text="{loc:Loc language-selector-label}"
                           Classes="WormFieldLabel" />
                <views:LanguageSelector HorizontalAlignment="Left"
                                        DataContext="{Binding Language}"
                                        Placement="BottomEdgeAlignedLeft" />
              </StackPanel>
            </Border>

            <Border Classes="WormInsetCard"
                    Padding="14">
              <StackPanel Spacing="10">
                <Button Classes="WormPillButton"
                        Content="{loc:Loc tab-options-account-settings}"
                        Command="{Binding OpenAccountSettings}"
                        HorizontalAlignment="Left" />
                <TextBlock Text="{loc:Loc tab-options-account-settings-desc}"
                           Classes="WormMuted"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Classes="WormSectionCard"
                Padding="18">
          <StackPanel Spacing="14">
            <TextBlock Text="{loc:Loc tab-options-hub-settings}"
                       Classes="WormSectionTitle" />

            <CheckBox Classes="WormCheck"
                      IsVisible="{Binding !DisableIncompatibleMacOS}"
                      IsChecked="{Binding CompatMode}"
                      Content="{loc:Loc tab-options-compatibility-mode}" />
            <CheckBox Classes="WormCheck"
                      IsVisible="{Binding DisableIncompatibleMacOS}"
                      IsChecked="False"
                      IsEnabled="False"
                      Opacity="0.8"
                      Content="{loc:Loc tab-options-compatibility-mode}" />
            <TextBlock IsVisible="{Binding !DisableIncompatibleMacOS}"
                       TextWrapping="Wrap"
                       Text="{loc:Loc tab-options-compatibility-mode-desc}"
                       Classes="WormMuted" />
            <TextBlock IsVisible="{Binding DisableIncompatibleMacOS}"
                       TextWrapping="Wrap"
                       Text="{loc:Loc tab-options-desc-incompatible}"
                       Classes="WormMuted" />

            <CheckBox Classes="WormCheck"
                      IsChecked="{Binding LogLauncherVerbose}"
                      Content="{loc:Loc tab-options-verbose-launcher-logging}" />
            <TextBlock TextWrapping="Wrap"
                       Text="{loc:Loc tab-options-verbose-launcher-logging-desc}"
                       Classes="WormMuted" />

            <CheckBox Classes="WormCheck"
                      IsChecked="{Binding OverrideAssets}"
                      Content="{loc:Loc tab-options-seasonal-branding}" />
            <TextBlock TextWrapping="Wrap"
                       Text="{loc:Loc tab-options-seasonal-branding-desc}"
                       Classes="WormMuted" />

            <Button Classes="WormPillButton"
                    Click="OpenHubSettings"
                    Content="{loc:Loc tab-options-hub-settings}"
                    HorizontalAlignment="Left" />
            <TextBlock TextWrapping="Wrap"
                       Text="{loc:Loc tab-options-hub-settings-desc}"
                       Classes="WormMuted" />
          </StackPanel>
        </Border>

        <Border Classes="WormSectionCard"
                Padding="18">
          <StackPanel Spacing="12">
            <WrapPanel Orientation="Horizontal">
              <Button Name="ClearEnginesButton"
                      Classes="WormPillButton"
                      Margin="0,0,10,10"
                      Content="{loc:Loc tab-options-clear-engines}"
                      Click="ClearEnginesPressed" />
              <Button Name="ClearServerContentButton"
                      Classes="WormPillButton"
                      Margin="0,0,10,10"
                      Content="{loc:Loc tab-options-clear-content}"
                      Click="ClearServerContentPressed" />
              <Button Classes="WormPillButton"
                      Margin="0,0,10,10"
                      Content="{loc:Loc tab-options-open-log-directory}"
                      Command="{Binding OpenLogDirectory}" />
            </WrapPanel>
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel x:Name="WormPanel"
                  Spacing="18"
                  IsVisible="False">
        <Border Classes="WormSectionCard"
                Padding="18">
          <StackPanel Spacing="14">
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Loc tab-options-worm-server-list-title}"
                         Classes="WormSectionTitle" />
              <TextBlock Text="{loc:Loc tab-options-worm-server-list-desc}"
                         Classes="WormMuted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Classes="WormInsetCard"
                    Padding="14">
              <StackPanel Spacing="10">
                <CheckBox Classes="WormCheck"
                          IsChecked="{Binding ServerListShowMode}"
                          Content="{loc:Loc tab-options-worm-show-mode}" />
                <CheckBox Classes="WormCheck"
                          IsChecked="{Binding ServerListShowMap}"
                          Content="{loc:Loc tab-options-worm-show-map}" />
                <CheckBox Classes="WormCheck"
                          IsChecked="{Binding ServerListShowPing}"
                          Content="{loc:Loc tab-options-worm-show-ping}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
